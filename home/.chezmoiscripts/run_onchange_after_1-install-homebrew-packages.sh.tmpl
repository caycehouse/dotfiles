#!/usr/bin/env bash

set -Eeufo pipefail

command -v brew >/dev/null 2>&1 || exit 0

# Brewfile hash: {{ include "dot_config/homebrew/Brewfile.tmpl" | sha256sum }}
export HOMEBREW_BUNDLE_FILE={{ .chezmoi.homeDir }}/.config/homebrew/Brewfile
export HOMEBREW_CASK_OPTS=--no-quarantine
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_ENV_HINTS=1

if ! command -v kubectl-krew >/dev/null 2>&1; then
  brew install krew
fi

ensure_krew_index() {
  local name=$1
  local url=$2

  if ! kubectl-krew index list | awk -v name="$name" 'NR > 1 && $1 == name { found=1 } END { exit !found }'; then
    kubectl-krew index add "$name" "$url"
  fi
}

ensure_krew_index kopiur https://github.com/home-operations/kopiur.git
ensure_krew_index netshoot https://github.com/nilic/kubectl-netshoot.git

echo "Running brew bundle"
brew bundle --no-upgrade

echo "Running brew bundle cleanup"
brew bundle cleanup --brews --casks --taps --mas --force || true
